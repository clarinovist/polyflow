# PolyFlow Environment Variables
# Copy to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────
# Local: postgresql://polyflow:polyflow@localhost:5434/polyflow
# Docker: postgresql://polyflow:YOUR_PASSWORD@polyflow-db:5434/polyflow
DATABASE_URL="postgresql://polyflow:polyflow@localhost:5434/polyflow"

# ─── Authentication ───────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="changeme"
NEXTAUTH_SECRET="changeme"
NEXTAUTH_URL="https://your-domain.com"

# ─── Docker Compose (Production DB) ──────────────────────────
POSTGRES_USER=polyflow
POSTGRES_PASSWORD=changeme
POSTGRES_DB=polyflow

# ─── Migrations ──────────────────────────────────────────────
# Set to 1 to skip auto-migrations on container start
SKIP_MIGRATIONS=0

# ─── AI / LLM (Optional) ─────────────────────────────────────
# LLM for Virtual CS chatbot
# Supports any OpenAI-compatible endpoint (Ollama, OpenRouter, etc.)
LLM_BASE_URL="http://localhost:11434/v1"
LLM_API_KEY=""
LLM_MODEL="deepseek-r1:7b"

# FIREWORKS_API_KEY=""
# FIREWORKS_MODEL_ID=""

# ─── Backup Script (Optional) ────────────────────────────────
# BACKUP_DIR="/opt/backups/polyflow"
# DB_CONTAINER="polyflow-db"
# RETENTION_DAYS=7

